# Docker Compose Settings
COMPOSE_PROJECT_NAME=esp_daemon
COMPOSE_BAKE=true

# ROS Settings
ROS_DISTRO=humble

# Optional runtime overrides
# TZ=Etc/UTC
# RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
# ROS_DOMAIN_ID=0
# MICRO_ROS_SERIAL_DEV=/dev/ttyACM0
# AUTO_BOOTSTRAP_MICRO_ROS=true
# MICRO_ROS_INSTALL_ARGS=--skip-rosdep
# ESP_DAEMON_PRIVILEGED=false
# DOCKER_USER=ros

# Optional build-time defaults (applied in Dockerfile)
# CONTAINER_TZ=Etc/UTC
# DEFAULT_RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
